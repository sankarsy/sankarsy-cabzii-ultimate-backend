# Must include scheme — e.g. mongodb://127.0.0.1:27017/cabzii or mongodb+srv://...
MONGODB_URI=mongodb://127.0.0.1:27017/cabzii
PORT=8000

# This backend is hosted at https://api.cabzii.in (point an "api" DNS A/CNAME
# record at your server, terminate TLS, and reverse-proxy to PORT above).
#
# FRONTEND_URL = comma-separated browser origins allowed by CORS.
# Include the site, www, the admin panel origin and your local dev ports.
# The admin panel lives at https://cabzii.in/admin (same origin as the site),
# so it is already covered by https://cabzii.in. Add admin.cabzii.in only if
# you split the admin panel onto its own subdomain later.
FRONTEND_URL=https://cabzii.in,https://www.cabzii.in,http://localhost:3000,http://localhost:3001,http://localhost:3002
JWT_SECRET=
JWT_EXPIRES_IN=7d

# OTP: use "local" for development (OTP shown in API response). Use "fast2sms" after Fast2SMS OTP verification.
OTP_MODE=local
OTP_LENGTH=6
OTP_TTL_MINUTES=5
# In development, if Fast2SMS fails, OTP is still saved and returned as debugOtp (set false to disable)
OTP_LOCAL_FALLBACK=true

# Fast2SMS
FAST2SMS_API_KEY=
FAST2SMS_SENDER_ID=CABZII
FAST2SMS_ENTITY_ID=
FAST2SMS_TEMPLATE_ID=
FAST2SMS_OTP_MESSAGE={otp} is your Cabzii login OTP. Do not share it.

# 2Factor.in
FACTOR2_API_KEY=
FACTOR2_TEMPLATE_NAME=cabzii
BRAND_NAME=Cabzii.in

# Optional: mark this phone as admin on OTP login
ADMIN_PHONE=
SUPER_ADMIN_PHONES=
VENDOR_ADMIN_MAP=9876543210:YourVendorName
ADMIN_LOGIN_PHONE=
ADMIN_LOGIN_PASSWORD=
PARTNER_LOGIN_PASSWORD=
