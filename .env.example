# Must include scheme. WRONG (crashes): mongodb+srv://user:pass@f62xoll.mongodb.net/...
# RIGHT: copy full string from MongoDB Atlas → Connect (includes cluster0.xxx or shard hosts).
MONGODB_URI=mongodb://127.0.0.1:27017/cabzii
PORT=8000
FRONTEND_URL=https://cabzii.in,http://localhost:3000,http://localhost:3001,http://localhost:3002
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Customer OTP only (6-digit). Partners/admins use password login.
# OTP_MODE: local | fast2sms | factor2
OTP_MODE=local
OTP_TTL_MINUTES=2
OTP_RESEND_COOLDOWN_SECONDS=30
# In development, if Fast2SMS fails, OTP is still saved and returned as debugOtp (set false to disable)
OTP_LOCAL_FALLBACK=true

# Fast2SMS (production: OTP_MODE=fast2sms + FAST2SMS_API_KEY)
FAST2SMS_API_KEY=
FAST2SMS_SENDER_ID=CABZII
FAST2SMS_ENTITY_ID=
FAST2SMS_TEMPLATE_ID=
FAST2SMS_QUICK_MESSAGE=Your OTP for Cabzii login is {otp}. It is valid for {minutes} minutes.
FAST2SMS_OTP_MESSAGE={otp} is your Cabzii login OTP. Do not share it.

# 2Factor.in
FACTOR2_API_KEY=
FACTOR2_TEMPLATE_NAME=cabzii
BRAND_NAME=Cabzii.in

# Optional: mark this phone as admin on OTP login
ADMIN_PHONE=
SUPER_ADMIN_PHONES=
VENDOR_ADMIN_MAP=9876543210:YourVendorName
ADMIN_LOGIN_PHONE=
ADMIN_LOGIN_PASSWORD=
PARTNER_LOGIN_PASSWORD=
