{
  "name": "cabzii-ultimate-backend",
  "version": "1.0.0",
  "description": "Backend API for cabzii.in taxi and tour booking platform",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "nodemon src/server.js",
    "prod": "node src/server.js",
    "seed": "node scripts/seedSampleData.js",
    "seed:drivers": "node scripts/seedDriversOnly.js",
    "seed:packages": "node scripts/seedPackagesOnly.js",
    "seed:content": "node scripts/seedBlogsTestimonials.js",
    "seed:sync": "node scripts/syncSampleDataFromTravel.js",
    "seed:cities": "node scripts/seedCities.js",
    "seed:locations": "node scripts/seedLocations.js",
    "migrate:cab-packages": "node scripts/migrateCabFarePackages.js",
    "migrate:driver-packages": "node scripts/migrateDriverFarePackages.js"
  },
  "keywords": [
    "cabzii",
    "taxi-booking",
    "cab-booking",
    "travel",
    "nodejs",
    "express",
    "mongodb"
  ],
  "author": "Cabzii",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-mongo-sanitize": "^2.2.0",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.1",
    "morgan": "^1.10.1",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
